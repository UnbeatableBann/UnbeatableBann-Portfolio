# GitHub Integration Config
GITHUB_USERNAME=your_github_username
# Optional: GITHUB_TOKEN=your_github_personal_access_token

# Medium Integration Config
MEDIUM_USERNAME=your_medium_username

# Cron Secret for forcing cached data refresh via route
CRON_SECRET=your_cron_secret

# Google Analytics 4 Measurement ID (optional — analytics disabled when absent)
# VITE_GA_ID=G-XXXXXXXXXX
